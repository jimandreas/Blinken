<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <!-- Transient runtime tracking, not user data - must not survive a reinstall/restore, since
         a restored postedAtMs can poison the continuous-mode safety cap for a reused notification
         key (see ActiveNotificationsStore.add). -->
    <cloud-backup>
        <exclude domain="sharedpref" path="blinken_active_notifications.xml"/>
        <exclude domain="sharedpref" path="blinken_eco_debounce.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="blinken_active_notifications.xml"/>
        <exclude domain="sharedpref" path="blinken_eco_debounce.xml"/>
    </device-transfer>
</data-extraction-rules>